{"config":{"lang":["ja"],"separator":"[\\s\\-\uff0c\u3002]+","pipeline":["stemmer"]},"docs":[{"location":"","title":"\u524d\u8a00","text":""},{"location":"#_2","title":"\u8fd9\u662f\u4ec0\u4e48","text":"<p>\u8fd9\u662f\u4e00\u4efd\u6307\u5357\uff0c\u65e8\u5728\u8ba9\u4f60\u66f4\u597d\u5730\u5ea6\u8fc7\u5728 INSA1 \u7684\u7559\u5b66\u65f6\u5149\u3002</p>"},{"location":"#_3","title":"\u4e3a\u4ec0\u4e48\u9700\u8981\u8fd9\u4efd\u6307\u5357","text":"<p>\u7559\u5b66\u7684\u65e5\u5b50\u91cc\uff0c\u6211\u4eec\u5728\u751f\u6d3b\u3001\u5b66\u4e60\u4e2d\u4f1a\u9047\u5230\u5404\u79cd\u5404\u6837\u7684\u95ee\u9898\u3002\u81ea\u5df1\u89e3\u51b3\u6709\u56f0\u96be\u65f6\uff0c\u6211\u4eec\u4f1a\u5411\u540c\u5c4a\u540c\u5b66\u6216\u662f\u5b66\u59d0\u5b66\u957f\u6c42\u52a9\u3002</p> <p>\u4f46\u8fd9\u79cd\u65b9\u5f0f\u4e3b\u8981\u6709\u4e24\u4e2a\u95ee\u9898\uff1a</p> <ol> <li> <p>\u4fe1\u606f\u4e0d\u51c6\u786e\u3002\u4ed6\u4eba\u7684\u53e3\u5934\u6216\u77ed\u5b57\u56de\u7b54\u6709\u65f6\u6a21\u7cca\uff0c\u8fc7\u65f6\uff0c\u751a\u81f3\u5b8c\u5168\u9519\u8bef\u3002</p> </li> <li> <p>\u6c9f\u901a\u6210\u672c\u9ad8\u3002\u63d0\u95ee\u8005\u9700\u8981\u7b49\u5f85\u7b54\u8005\u7684\u56de\u5e94\u3002\u5982\u679c\u95ee\u9898\u4e4b\u524d\u88ab\u95ee\u8fc7\u4e86\uff0c\u4e5f\u5f92\u589e\u7b54\u8005\u7684\u8d1f\u62c5\u3002</p> </li> </ol> <p>\u8fd9\u4efd\u6307\u5357\u5219\u81f4\u529b\u4e8e\u63d0\u4f9b\u51c6\u786e\u65e0\u8bef\u7684\u77e5\u8bc6\uff0c\u505a\u5230\u77e5\u8bc6\u5171\u4eab\u3002</p>"},{"location":"#_4","title":"\u5982\u4f55\u4f7f\u7528","text":"<p>\u4f60\u53ef\u4ee5\u5728\u5de6\u4fa7\u83dc\u5355\u680f\u91cc\u9009\u62e9\u4f60\u60f3\u4e86\u89e3\u7684\u6761\u76ee\uff0c\u4e5f\u53ef\u4ee5\u76f4\u63a5\u641c\u7d22\u5173\u952e\u8bcd\u3002</p>"},{"location":"#_5","title":"\u5982\u4f55\u8d21\u732e","text":"<p>\u6b22\u8fce Pull Request (\u4fdd\u59c6\u6559\u7a0b \u82f1\u6587\uff5c\u4e2d\u6587)</p> <p>\u4f60\u4e5f\u53ef\u4ee5\u90ae\u4ef6\u8054\u7cfb\u6211 yikang.su@insa-lyon.fr</p> <ol> <li> <p>\u8fd9\u91cc\u7684 INSA \u4e00\u5f8b\u6307 INSA \u91cc\u6602\u6821\u533a\u00a0\u21a9</p> </li> </ol>"},{"location":"%E8%B5%B4%E6%B3%95%E5%89%8D%E5%87%86%E5%A4%87/","title":"\u8d74\u6cd5\u524d\u51c6\u5907","text":"<p>\u656c\u8bf7\u671f\u5f85</p>"},{"location":"%E5%AE%9E%E4%B9%A0/%E5%AE%9E%E4%B9%A0%E6%A6%82%E5%86%B5/","title":"\u5b9e\u4e60","text":"<p>INSA \u7684\u5b9e\u4e60\u4e3b\u8981\u5206\u5de5\u4eba\u5b9e\u4e60\u548c\u4e13\u4e1a\u5b9e\u4e60\u3002</p> <ul> <li> <p>\u5de5\u4eba\u5b9e\u4e60\u5728\u5927\u4e00\u6216\u5927\u4e8c\u7684\u6691\u5047\uff0c\u65f6\u957f\u4e00\u4e2a\u6708\u3002</p> </li> <li> <p>\u4e13\u4e1a\u5b9e\u4e60\u8d2f\u7a7f\u5927\u4e09\u81f3\u5927\u4e94\uff0c\u5b89\u6392\u56e0\u4e13\u4e1a\u800c\u5f02\u3002</p> </li> </ul> <p>\u6765\u6e90\uff1a\u5b66\u6821\u5b98\u7f51\u4fe1\u606f</p>"},{"location":"%E7%94%9F%E5%AD%98/%E4%B8%AA%E4%BA%BA%E5%AE%89%E5%85%A8/","title":"\u4e2a\u4eba\u5b89\u5168","text":""},{"location":"%E7%94%9F%E5%AD%98/%E4%B8%AA%E4%BA%BA%E5%AE%89%E5%85%A8/#_2","title":"\u4eba\u8eab\u5b89\u5168","text":""},{"location":"%E7%94%9F%E5%AD%98/%E4%B8%AA%E4%BA%BA%E5%AE%89%E5%85%A8/#_3","title":"\u8d22\u4ea7\u5b89\u5168","text":""},{"location":"%E7%94%9F%E5%AD%98/%E5%BF%85%E5%8A%9E%E4%BA%8B%E9%A1%B9/","title":"\u5fc5\u529e\u4e8b\u9879","text":"<ul> <li>\u7535\u8bdd\u5361</li> <li>\u94f6\u884c\u5361</li> <li>\u533b\u4fdd</li> </ul>"},{"location":"%E7%94%9F%E5%AD%98/%E8%A1%A3%E9%A3%9F%E4%BD%8F%E8%A1%8C/","title":"\u8863\u98df\u4f4f\u884c","text":""},{"location":"%E7%94%9F%E5%AD%98/%E8%A1%A3%E9%A3%9F%E4%BD%8F%E8%A1%8C/#_2","title":"\u6d17\u8863","text":""},{"location":"%E7%94%9F%E5%AD%98/%E8%A1%A3%E9%A3%9F%E4%BD%8F%E8%A1%8C/#_3","title":"\u5b66\u6821\u6d17\u8863\u623f","text":"<p>\u5b66\u6821\u6d17\u8863\u623f\u7684\u914d\u7f6e\u5982\u4e0b\uff1a</p> <ul> <li>B\u680b\uff1a1\u53f010\u516c\u65a4\u6d17\u8863\u673a\u30014\u53f07\u516c\u65a4\u6d17\u8863\u673a\u30011\u4e2a\u70d8\u5e72\u673a</li> <li>D\u680b\uff1a7\u53f07\u516c\u65a4\u6d17\u8863\u673a\u30012\u4e